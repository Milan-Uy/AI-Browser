# Copy this file to .env and fill in your values.
# Load it before starting the server: set -a && source .env && set +a
# (or use a tool like python-dotenv, direnv, etc.)

# ── LLM backend ──────────────────────────────────────────────────────────────

# Which LLM to use. Options: mock (default) | gemini
AIB_LLM_BACKEND=mock

# Required when AIB_LLM_BACKEND=gemini
# GEMINI_API_KEY=your-key-here

# ── Logging ───────────────────────────────────────────────────────────────────

# Python log level passed to logging.basicConfig. Options: DEBUG | INFO | WARNING | ERROR
AIB_LOG_LEVEL=INFO

# Set to 1 to dump full page text and history in llm_request log lines (can be verbose)
# AIB_LOG_LLM_FULL=1

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated extra origins allowed by the backend.
# Defaults to chrome-extension://* (always included).
# Example: AIB_ALLOW_ORIGINS=http://localhost:3000,https://myapp.example.com
# AIB_ALLOW_ORIGINS=
