# Copy this file to .env and fill in your values.
# Load it before starting the server: set -a && source .env && set +a
# (or use a tool like python-dotenv, direnv, etc.)

# ── LLM backend ──────────────────────────────────────────────────────────────

# Which LLM to use. Options: mock (default) | gemini | gauss
AIB_LLM_BACKEND=mock

# Required when AIB_LLM_BACKEND=gemini
# GEMINI_API_KEY=your-key-here

# Required when AIB_LLM_BACKEND=gauss (Gauss OpenAPI: POST /openapi/chat/v1/messages)
# AIB_GAUSS_API_URL=https://your-gauss-host.example.com
# AIB_GAUSS_CLIENT=<x-generative-ai-client header value>
# AIB_GAUSS_TOKEN=<x-openapi-token header value>
# AIB_GAUSS_MODEL_IDS=model-id-a,model-id-b
# AIB_GAUSS_USER_EMAIL=                                    # optional
# AIB_GAUSS_ENDPOINT_PATH=/openapi/chat/v1/messages         # override if your path differs
# AIB_GAUSS_STREAM=1                                        # 0 to disable streaming

# ── Logging ───────────────────────────────────────────────────────────────────

# Python log level passed to logging.basicConfig. Options: DEBUG | INFO | WARNING | ERROR
AIB_LOG_LEVEL=INFO

# Set to 1 to dump full page text and history in llm_request log lines (can be verbose)
# AIB_LOG_LLM_FULL=1

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated extra origins allowed by the backend.
# Defaults to chrome-extension://* (always included).
# Example: AIB_ALLOW_ORIGINS=http://localhost:3000,https://myapp.example.com
# AIB_ALLOW_ORIGINS=
